# KiCad gitignore template

# Temporary files
*.tmp
*-bak
*-backups
*.bak

# User-specific layout / settings files
*.kicad_prl
*.kicad_user
fp-info-cache

# Autosave files
*_autosave*

# Lock files
*.lck

# DRC reports and outputs
*.drc
*.rpt
*.pdf
*.gbr
*.drl
*.pos
*.svg
*.dxf
plot/
gerber/
output/
